{
  "exlusive": true,
  "reload_style_on_change": true,
  "position": "top",
  "spacing": 0,
  "height": 0,
  "margin-top": 2,
  "margin-left": 5,
  "margin-right": 5,
  "margin-bottom": 0,
  "modules-left": [
    "cpu",
    "memory",
    "disk"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "pulseaudio",
    "custom/separator",
    "network",
    "custom/separator",
    "custom/notification",
    "group/tray-expander"
  ],
  "clock": {
    "interval": 1,
    "timezone": "Europe/Berlin",
    "format": "<b>{:%H:%M - %d.%m.%Y}</b>",
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
      "mode": "month",
      "format": {
        "month": "<span color='#ffead3'><b>{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>",
      }
    }
  },
  "cpu": {
    "interval": 10,
    "format": "ΎΜδ {usage}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "ΎΔΚ {used:0.2f}GB",
    "max-length": 10,
    "tooltip": false,
    "warning": 70,
    "critical": 90
  },
  "network": {
    "interval": 2,
    "format": "ΎΖ╡ {bandwidthDownBytes}  ΎΖ╢ {bandwidthUpBytes} {icon}",
    "format-alt": "{ipaddr}/{cidr} {icon}",
    "format-alt-click": "click-right",
    "format-wifi": "{icon} ({signalStrength}%)",
    "format-icons": {
      "wifi": [
        "≤░νθ",
        "≤░νλ",
        "≤░νρ"
      ],
      "ethernet": [
        "Ύδ┐"
      ],
      "disconnected": [
        "ΌτΡ"
      ]
    },
    "on-click": "nm-connection-editor",
    "tooltip-format": "{ifname}: {ipaddr}",
  },
  "pulseaudio": {
    "format": "{icon} {volume}% {format_source}",
    "format-bluetooth": "{icon}ΎΛΦ {volume}% {format_source}",
    "format-bluetooth-muted": "ΎΣο {format_source}",
    "format-muted": "ΎΣο  {format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΏθΟπ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ "
      ]
    },
    "on-click": "pavucontrol"
  },
  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item"
    },
    "modules": [
      "custom/expand-icon",
      "tray"
    ]
  },
  "custom/expand-icon": {
    "format": "ΎΔυ ",
    "tooltip": false
  },
  "tray": {
    "icon-size": 12,
    "spacing": 12
  },
  "custom/separator": {
    "format": "|",
    "tooltip": false
  },
  "disk": {
    "format": "ΎΓι {free}"
  },
  "custom/notification": {
    "tooltip": true,
    "format": "<span size='10pt'>{icon}</span>",
    "format-icons": {
      "notification": "≤▒Ζτ ",
      "none": "≤░Γε ",
      "dnd-notification": "≤░Γι ",
      "dnd-none": "≤░ςΥ ",
      "inhibited-notification": "≤░Γδ ",
      "inhibited-none": "≤░ςΣ ",
      "dnd-inhibited-notification": "≤░Γδ ",
      "dnd-inhibited-none": "≤░ςΣ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
