exec-once = hyprpm reload -n
exec-once = waybar -c $HOME/.config/waybar/config
exec-once = openrgb --startminimized -p $HOME/.config/OpenRGB/1.orp
exec-once = /usr/lib/polkit-kde-authentication-agent-1
exec = swaync
exec-once = env QT_QPA_PLATFORM=xcb copyq --start-server
exec-once = awww-daemon
exec-once = sleep 3 && $HOME/.config/hypr/quodlibet-duck.sh --daemonize

exec-once = dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP
exec-once = systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP
exec-once = hash dbus-update-activation-environment 2>/dev/null && dbus-update-activation-environment --systemd --all

exec = snappy-switcher --daemon
exec = sleep 2 & hyprshade toggle vibrance-gud
exec = sleep 5 & noisetorch -s alsa_input.usb-R__DE_Microphones_R__DE_NT-USB_Mini_73B04B6B-00.mono-fallback -i -t 95
